page {
  background: linear-gradient(180deg, #e8f0f8 0%, #f0f4f8 100%);
  min-height: 100vh;
}

.container {
  padding: 0;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.posts-container {
  padding: 40rpx 20rpx;
}

.loading,
.empty {
  text-align: center;
  padding: 100rpx 20rpx;
  color: #8898aa;
  font-size: 28rpx;
}

.empty .post-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  border: none;
}

.post-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-time {
  font-size: 24rpx;
  color: #99aab5;
}

.post-content {
  margin-bottom: 24rpx;
}

.post-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #2c3e50;
  display: block;
  word-break: break-all;
}

.voice-indicator {
  margin-top: 16rpx;
  display: inline-block;
  background: #e8f0f8;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #667eea;
}

.post-footer {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e8f0f8;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.icon {
  font-size: 32rpx;
}

.count {
  font-size: 26rpx;
  color: #8898aa;
}
