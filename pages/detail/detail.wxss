page {
  background: linear-gradient(180deg, #e8f0f8 0%, #f0f4f8 100%);
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.container {
  padding: 0;
}

/* 帖子详情 */
.post-detail {
  background: white;
  margin: 20rpx;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.post-time {
  font-size: 24rpx;
  color: #99aab5;
}

.mine-tag {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.post-content {
  margin-bottom: 32rpx;
}

.content-text {
  font-size: 32rpx;
  line-height: 1.8;
  color: #2c3e50;
  display: block;
  word-break: break-all;
}

/* 语音播放 */
.voice-player {
  margin-top: 24rpx;
}

.play-btn {
  width: 100%;
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  border-radius: 50rpx;
  padding: 30rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

/* 鼓励区域 */
.encourage-section {
  text-align: center;
  padding: 30rpx 0;
  border-top: 2rpx solid #e8f0f8;
}

.encourage-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50rpx;
  padding: 30rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.encourage-btn.active {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.encourage-btn:active {
  transform: scale(0.98);
}

.heart-icon {
  font-size: 40rpx;
}

.heart-icon.pulse {
  animation: pulse 0.6s ease-in-out;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.count {
  font-size: 28rpx;
  opacity: 0.9;
}

.encourage-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #8898aa;
}

/* 评论区 */
.comments-section {
  padding: 40rpx 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.comment-count {
  font-size: 26rpx;
  color: #8898aa;
}

/* 评论列表 */
.comments-list {
  margin-bottom: 20rpx;
}

.comment-item {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.comment-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
}

.comment-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #2c3e50;
  display: block;
  word-break: break-all;
}

.comment-voice {
  margin-top: 12rpx;
}

.mini-play-btn {
  background: #e8f0f8;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #667eea;
  border: none;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.mini-play-btn:active {
  opacity: 0.8;
}

.comment-time {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #99aab5;
}

.no-comments {
  text-align: center;
  padding: 60rpx 20rpx;
  color: #8898aa;
  font-size: 28rpx;
}

/* 评论输入框 - 微信风格（蓝色主题）*/
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #f5f5f5;
  border-top: 1rpx solid #e5e5e5;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 1000;
}

.input-bar-inner {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 语音按钮 - 微信风格 */
.voice-btn {
  width: 64rpx;
  height: 64rpx;
  background: transparent;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  flex-shrink: 0;
}

.voice-icon-text {
  font-size: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recording-icon-text {
  font-size: 36rpx;
}

/* 输入框容器 */
.input-container {
  flex: 1;
  background: white;
  border-radius: 44rpx;
  padding: 20rpx 32rpx;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  position: relative;
  border: 1rpx solid #e5e5e5;
}

.comment-textarea {
  flex: 1;
  font-size: 32rpx;
  line-height: 1.5;
  color: #333;
  max-height: 300rpx;
  padding: 0;
  margin: 0;
  background: transparent;
}

.comment-textarea::placeholder {
  color: #999;
}

.textarea-voice-icon {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  opacity: 0.5;
}

/* 表情按钮 */
.emoji-btn {
  width: 64rpx;
  height: 64rpx;
  background: transparent;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  flex-shrink: 0;
}

.emoji-icon-text {
  font-size: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 发送按钮 */
.send-btn {
  min-width: 128rpx;
  height: 64rpx;
  background: #e0e0e0;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0 24rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.send-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.send-btn.active:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.send-btn:disabled {
  background: #e0e0e0;
  opacity: 0.6;
}

.send-text {
  font-size: 28rpx;
  color: white;
  font-weight: 500;
}

.send-btn:not(.active) .send-text {
  color: #999;
}

/* 录音提示 */
.recording-hint {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(0, 0, 0, 0.75);
  padding: 18rpx 28rpx;
  border-radius: 44rpx;
  align-self: center;
}

.hint-icon {
  font-size: 36rpx;
  animation: recording-wave 1s infinite;
}

@keyframes recording-wave {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.2);
  }
}

.hint-text {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
}
